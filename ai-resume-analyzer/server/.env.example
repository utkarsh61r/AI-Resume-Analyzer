PORT=5000
CLIENT_URL=http://localhost:5173

# MongoDB Atlas free tier — get yours at https://mongodb.com/atlas
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/resume-analyzer?retryWrites=true&w=majority

# JWT Secret — change this to a random string in production
JWT_SECRET=your-super-secret-jwt-key-change-me

# AI Keys (at least one recommended; app works without them using rule-based fallback)
# Groq free tier — https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenRouter free tier — https://openrouter.ai/keys  (fallback)
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
